<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.asgard.colima</string>
    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/colima</string>
        <string>start</string>
        <string>--kubernetes</string>
        <string>--cpu</string>
        <string>6</string>
        <string>--memory</string>
        <string>12</string>
        <string>--disk</string>
        <string>60</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>
    <key>StandardOutPath</key>
    <string>/tmp/colima-asgard.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/colima-asgard.err</string>
    <key>ThrottleInterval</key>
    <integer>60</integer>
</dict>
</plist>
