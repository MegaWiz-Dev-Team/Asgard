# ╔══════════════════════════════════════════════════════════════╗
# ║  🏰 ASGARD — Environment Variables Template                ║
# ║  Copy to .env and fill in actual values                     ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Infrastructure ──
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=mimir
MYSQL_USER=mimir
MYSQL_PASSWORD=change-me
POSTGRES_PASSWORD=change-me
NEO4J_PASSWORD=change-me

# ── Heimdall (LLM Gateway, on host) ──
HEIMDALL_PORT=8080
HEIMDALL_API_KEY=
HEIMDALL_MODEL=mlx-community/Qwen3.5-9B-MLX-4bit
HEIMDALL_BACKEND_ENGINE=mlx
HEIMDALL_BACKEND_PORT=8081
HEIMDALL_GATEWAY_PORT=8080

# ── Embedding ──
EMBEDDING_PORT=8001
EMBEDDING_HOST=127.0.0.1
EMBEDDING_MODEL=BAAI/bge-m3

# ── Mimir ──
MIMIR_API_PORT=3000
MIMIR_DASHBOARD_PORT=3001
MIMIR_EMBED_MODEL=nomic-embed-text
MIMIR_CRON_TICK_SECONDS=60

# ── Auth ──
JWT_SECRET=change-me-in-production

# ── External AI ──
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# ── S3 / Object Storage ──
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=mimir-uploads
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# ── Vault ──
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=
VAULT_MOUNT=secret
VAULT_PATH=mimir/secrets

# ── Yggdrasil (Auth) ──
ZITADEL_PORT=8085
ZITADEL_EXTERNALDOMAIN=localhost
ZITADEL_MASTERKEY=change-me
ZITADEL_ADMIN_EMAIL=admin@asgardai.dev
ZITADEL_ADMIN_PASSWORD=change-me

# ── Bifrost ──
BIFROST_PORT=8100
BIFROST_DEFAULT_MODEL=qwen3.5
BIFROST_MAX_ITERATIONS=10
BIFROST_MAX_EXECUTION_TIME=120

# ── Fenrir ──
FENRIR_PORT=8200
FENRIR_BROWSER_HEADLESS=true

# ── Eir/OpenEMR ──
OPENEMR_PORT=80
OPENEMR_MYSQL_PASSWORD=change-me
OPENEMR_ADMIN_PASSWORD=change-me

# ── General ──
LOG_LEVEL=info
RUST_LOG=info
EXTERNAL_MODEL_DIR="/Volumes/T7 Shield/Development/AI_Models"
